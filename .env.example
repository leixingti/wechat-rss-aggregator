# ==========================================
# 应用核心配置
# ==========================================

# 服务器端口（默认：3000）
PORT=3000

# 监听地址（默认：0.0.0.0，允许外部访问）
HOST=0.0.0.0

# 运行环境（development / production）
NODE_ENV=production

# ==========================================
# 数据库配置
# ==========================================

# 数据库文件路径
# - 本地开发：使用项目目录下的 articles.db
# - 云服务器：使用 /data/articles.db 或其他持久化路径
# 如果不配置，应用会自动选择：/app/data -> /data -> ~/.wechat-rss -> 项目目录
# DB_PATH=/data/articles.db

# ==========================================
# RSS 配置
# ==========================================

# RSS 配置文件路径
# 如果不配置，应用会自动选择：/app/data -> /data -> ~/.wechat-rss -> 项目目录
# CONFIG_PATH=/data

# RSS 抓取间隔（分钟，默认：15）
# FETCH_INTERVAL=15

# ==========================================
# 日志配置
# ==========================================

# 日志目录路径
# 如果不配置，默认使用：~/.wechat-rss/logs
# LOG_DIR=/var/log/wechat-rss

# 日志级别（debug / info / warn / error）
# LOG_LEVEL=info

# ==========================================
# AI 摘要功能（可选）
# ==========================================

# DeepSeek API 密钥（用于生成 AI 摘要）
# 获取地址：https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-xxx...

# 或使用 Anthropic Claude API
# ANTHROPIC_API_KEY=sk-ant-xxx...

# ==========================================
# 国际化和翻译（可选）
# ==========================================

# 是否启用翻译功能
# ENABLE_TRANSLATION=false

# ==========================================
# 监控和性能
# ==========================================

# 最大 WebSocket 连接数（默认：1000）
# MAX_WS_CONNECTIONS=1000

# 数据库连接超时（毫秒，默认：5000）
# DB_TIMEOUT=5000

# ==========================================
# 云平台特定配置
# ==========================================

# 腾讯云 COS（对象存储）配置（可选）
# TENCENT_COS_BUCKET=your-bucket
# TENCENT_COS_REGION=ap-beijing
# TENCENT_COS_SECRET_ID=xxx
# TENCENT_COS_SECRET_KEY=xxx

# ==========================================
# 安全配置
# ==========================================

# 管理后台密码（默认：admin123）
# ADMIN_PASSWORD=admin123

# API 速率限制（请求/分钟）
# RATE_LIMIT=100
