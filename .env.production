# ==========================================
# 腾讯云生产环境配置
# ==========================================

# 基础配置
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# 数据库持久化配置（腾讯云推荐路径）
DB_PATH=/data/articles.db

# RSS 配置路径
CONFIG_PATH=/data

# 日志配置
LOG_DIR=/var/log/wechat-rss
LOG_LEVEL=info

# ==========================================
# 注意事项
# ==========================================
# 1. 部署前，请在腾讯云服务器上创建以下目录：
#    mkdir -p /data /var/log/wechat-rss
#    chmod 755 /data /var/log/wechat-rss
#
# 2. 如果需要 AI 摘要功能，添加 API 密钥：
#    DEEPSEEK_API_KEY=sk-xxx...
#    或
#    ANTHROPIC_API_KEY=sk-ant-xxx...
#
# 3. 修改管理员密码（强烈建议）：
#    rss-manager.js 中的 DEFAULT_CONFIG.password
#
# 4. WebSocket 配置可根据服务器资源调整
# ==========================================
