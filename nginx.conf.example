# ================================================
# Nginx 配置文件 - 腾讯云服务器 43.167.164.233
# ================================================
# 保存位置：/etc/nginx/sites-available/wechat-rss
# 启用命令：sudo ln -s /etc/nginx/sites-available/wechat-rss /etc/nginx/sites-enabled/
# 测试配置：sudo nginx -t
# 重启服务：sudo systemctl restart nginx
# ================================================

# ================================================
# 上游服务器定义
# ================================================
upstream wechat_rss_backend {
  # PM2 集群模式会在 3000-3099 之间分配端口
  # 这里只需要指向主端口，Nginx 会自动负载均衡
  server 127.0.0.1:3000;

  # 连接保活配置
  keepalive 64;
}

# ================================================
# HTTP 重定向到 HTTPS（可选，有域名时启用）
# ================================================
# server {
#   listen 80;
#   listen [::]:80;
#   server_name example.com www.example.com;
#
#   # 所有流量重定向到 HTTPS
#   return 301 https://$server_name$request_uri;
# }

# ================================================
# 主服务器配置 - HTTP
# ================================================
server {
  listen 80 default_server;
  listen [::]:80 default_server;

  server_name _;

  # ================================================
  # 日志配置
  # ================================================
  access_log /var/log/nginx/wechat-rss.log combined buffer=32k flush=5s;
  error_log /var/log/nginx/wechat-rss-error.log warn;

  # ================================================
  # 缓冲和超时配置
  # ================================================
  # 客户端最大请求体大小（上传文件限制）
  client_max_body_size 50M;

  # 连接超时
  keepalive_timeout 65;

  # ================================================
  # 安全头配置
  # ================================================
  add_header X-Frame-Options "SAMEORIGIN" always;
  add_header X-Content-Type-Options "nosniff" always;
  add_header X-XSS-Protection "1; mode=block" always;
  add_header Referrer-Policy "no-referrer-when-downgrade" always;

  # ================================================
  # 反向代理配置
  # ================================================
  location / {
    proxy_pass http://wechat_rss_backend;
    proxy_http_version 1.1;

    # ============ WebSocket 支持（重要） ============
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection 'upgrade';

    # ============ 请求头转发 ============
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $server_name;
    proxy_set_header X-Forwarded-Port $server_port;

    # ============ 超时配置（WebSocket 需要较长超时） ============
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
    proxy_request_timeout 60s;

    # ============ 缓冲配置（WebSocket 需要禁用缓冲） ============
    proxy_buffering off;
    proxy_request_buffering off;

    # ============ 缓存控制 ============
    proxy_cache_bypass $http_upgrade;
  }

  # ================================================
  # 静态文件缓存优化
  # ================================================
  location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|map)$ {
    expires 30d;
    add_header Cache-Control "public, immutable";
    access_log off;
    log_not_found off;
  }

  # ================================================
  # 禁止访问敏感文件
  # ================================================
  location ~ /\. {
    deny all;
    access_log off;
    log_not_found off;
  }

  location ~ ~$ {
    deny all;
    access_log off;
    log_not_found off;
  }

  # 禁止访问敏感配置文件
  location ~ /\.(env|git|gitignore|htaccess|htpasswd|lock|sql|swp|swo)$ {
    deny all;
    access_log off;
    log_not_found off;
  }
}

